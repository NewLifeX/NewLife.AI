<?xml version="1.0" encoding="utf-8"?>
<EntityModel xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" xs:schemaLocation="https://newlifex.com https://newlifex.com/Model202509.xsd" Document="https://newlifex.com/xcode/model" ModelVersion="2.0.2026.130" xmlns="https://newlifex.com/Model202509.xsd">
  <Option>
    <!--类名模板。其中{name}替换为Table.Name，如{name}Model/I{name}Dto等-->
    <ClassNameTemplate />
    <!--显示名模板。其中{displayName}替换为Table.DisplayName-->
    <DisplayNameTemplate />
    <!--基类。可能包含基类和接口，其中{name}替换为Table.Name-->
    <BaseClass>Entity</BaseClass>
    <!--命名空间-->
    <Namespace>NewLife.ChatAI.Entity</Namespace>
    <!--引用命名空间-->
    <ExtendNameSpace />
    <!--输出目录-->
    <Output>.\</Output>
    <!--是否使用中文文件名。默认false-->
    <ChineseFileName>True</ChineseFileName>
    <!--用于生成Copy函数的参数类型。例如{name}或I{name}-->
    <ModelNameForCopy />
    <!--带有索引器。实现IModel接口-->
    <HasIModel>False</HasIModel>
    <!--可为null上下文。生成String?等-->
    <Nullable>False</Nullable>
    <!--数据库连接名-->
    <ConnName>ChatAI</ConnName>
    <!--模型类模版。设置后生成模型类，用于接口数据传输，例如{name}Model-->
    <ModelClass>{name}Model</ModelClass>
    <!--模型类输出目录。默认当前目录的Models子目录-->
    <ModelsOutput>..\Models\</ModelsOutput>
    <!--模型接口模版。设置后生成模型接口，用于约束模型类和实体类，例如I{name}-->
    <ModelInterface />
    <!--模型接口输出目录。默认当前目录的Interfaces子目录-->
    <InterfacesOutput>.\Interfaces\</InterfacesOutput>
    <!--用户实体转为模型类的模型类。例如{name}或{name}DTO-->
    <ModelNameForToModel />
    <!--命名格式。Default/Upper/Lower/Underline-->
    <NameFormat>Default</NameFormat>
    <!--魔方区域显示名-->
    <DisplayName>AI对话</DisplayName>
    <!--魔方控制器输出目录-->
    <CubeOutput>../Areas/ChatAI/</CubeOutput>
  </Option>
  <Tables>
    <Table Name="Conversation" Description="会话。一次完整的多轮对话上下文">
      <Columns>
        <Column Name="Id" DataType="Int64" Identity="True" PrimaryKey="True" Description="编号" />
        <Column Name="UserId" DataType="Int32" Description="用户。会话所属用户" />
        <Column Name="Title" DataType="String" Master="True" Length="200" Description="标题。会话标题，显示在侧边栏" />
        <Column Name="ModelCode" DataType="String" Description="模型编码。当前使用的模型" />
        <Column Name="ThinkingMode" DataType="Int32" Description="思考模式。Auto=0自动, Think=1思考, Fast=2快速" />
        <Column Name="IsPinned" DataType="Boolean" Description="置顶。是否置顶显示" />
        <Column Name="MessageCount" DataType="Int32" Description="消息数" />
        <Column Name="LastMessageTime" DataType="DateTime" Description="最后消息时间。用于排序" />
        <Column Name="CreateUserID" DataType="Int32" Description="创建用户" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="UpdateUserID" DataType="Int32" Description="更新用户" Category="扩展" />
        <Column Name="UpdateIP" DataType="String" Description="更新地址" Category="扩展" />
        <Column Name="UpdateTime" DataType="DateTime" Description="更新时间" Category="扩展" />
        <Column Name="Remark" DataType="String" Length="500" Description="备注" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="UserId,LastMessageTime" />
        <Index Columns="UserId,IsPinned" />
      </Indexes>
    </Table>
    <Table Name="ChatMessage" Description="对话消息。会话中的单条发言，包括用户消息和AI回复">
      <Columns>
        <Column Name="Id" DataType="Int64" Identity="True" PrimaryKey="True" Description="编号" />
        <Column Name="ConversationId" DataType="Int64" Description="会话。所属会话" />
        <Column Name="Role" DataType="String" Description="角色。User=用户, Assistant=AI助手" />
        <Column Name="Content" DataType="String" ShowIn="Auto,-List,-Search" Length="-1" Description="内容。Markdown格式文本" />
        <Column Name="ThinkingContent" DataType="String" ShowIn="Auto,-List,-Search" Length="-1" Description="思考内容。思考模式下的推理过程" />
        <Column Name="ThinkingMode" DataType="Int32" Description="思考模式。Auto=0自动, Think=1思考, Fast=2快速" />
        <Column Name="Attachments" DataType="String" ShowIn="Auto,-List,-Search" Length="2000" Description="附件列表。JSON格式，存储魔方附件ID数组" />
        <Column Name="ToolCalls" DataType="String" ShowIn="Auto,-List,-Search" Length="-1" Description="工具调用。JSON格式，存储tool_call链路记录" />
        <Column Name="PromptTokens" DataType="Int32" Description="提示Token数" />
        <Column Name="CompletionTokens" DataType="Int32" Description="回复Token数" />
        <Column Name="TotalTokens" DataType="Int32" Description="总Token数" />
        <Column Name="CreateUserID" DataType="Int32" Description="创建用户" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="UpdateUserID" DataType="Int32" Description="更新用户" Category="扩展" />
        <Column Name="UpdateIP" DataType="String" Description="更新地址" Category="扩展" />
        <Column Name="UpdateTime" DataType="DateTime" Description="更新时间" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="ConversationId,CreateTime" />
      </Indexes>
    </Table>
    <Table Name="MessageFeedback" Description="消息反馈。用户对AI回复的点赞或点踩">
      <Columns>
        <Column Name="Id" DataType="Int64" Identity="True" PrimaryKey="True" Description="编号" />
        <Column Name="MessageId" DataType="Int64" Description="消息。被反馈的消息" />
        <Column Name="UserId" DataType="Int32" Description="用户。反馈用户" />
        <Column Name="FeedbackType" DataType="Int32" Description="反馈类型。Like=1点赞, Dislike=2点踩" />
        <Column Name="Reason" DataType="String" Length="500" Description="原因。点踩原因" />
        <Column Name="AllowTraining" DataType="Boolean" Description="允许训练。是否允许用于模型学习训练" />
        <Column Name="CreateUserID" DataType="Int32" Description="创建用户" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="UpdateUserID" DataType="Int32" Description="更新用户" Category="扩展" />
        <Column Name="UpdateIP" DataType="String" Description="更新地址" Category="扩展" />
        <Column Name="UpdateTime" DataType="DateTime" Description="更新时间" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="MessageId,UserId" Unique="True" />
        <Index Columns="MessageId" />
        <Index Columns="UserId" />
      </Indexes>
    </Table>
    <Table Name="SharedConversation" Description="共享会话。通过链接分享的对话快照">
      <Columns>
        <Column Name="Id" DataType="Int64" Identity="True" PrimaryKey="True" Description="编号" />
        <Column Name="ConversationId" DataType="Int64" Description="会话。被分享的会话" />
        <Column Name="ShareToken" DataType="String" Description="分享令牌。唯一标识，用于生成分享URL" />
        <Column Name="SnapshotMessageId" DataType="Int64" Description="快照消息。截止到的最后一条消息编号" />
        <Column Name="CreatorUserId" DataType="Int32" Description="创建者。分享发起用户" />
        <Column Name="ExpireTime" DataType="DateTime" Description="过期时间。null表示永不过期" />
        <Column Name="CreateUserID" DataType="Int32" Description="创建用户" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="UpdateUserID" DataType="Int32" Description="更新用户" Category="扩展" />
        <Column Name="UpdateIP" DataType="String" Description="更新地址" Category="扩展" />
        <Column Name="UpdateTime" DataType="DateTime" Description="更新时间" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="ShareToken" Unique="True" />
        <Index Columns="ConversationId" />
        <Index Columns="CreatorUserId" />
      </Indexes>
    </Table>
    <Table Name="ModelConfig" Description="模型配置。后端接入的大语言模型">
      <Columns>
        <Column Name="Id" DataType="Int32" Identity="True" PrimaryKey="True" Description="编号" />
        <Column Name="Code" DataType="String" Description="编码。模型唯一标识" />
        <Column Name="Name" DataType="String" Master="True" Description="名称。显示名称" />
        <Column Name="Provider" DataType="String" Description="提供商。OpenAI、Alibaba、DeepSeek等" />
        <Column Name="Endpoint" DataType="String" ShowIn="Auto,-List,-Search" Length="500" Description="接口地址。API地址" />
        <Column Name="ApiKey" DataType="String" ShowIn="Auto,-List,-Search" Length="500" Description="密钥。API访问密钥" />
        <Column Name="MaxTokens" DataType="Int32" Description="最大令牌数" />
        <Column Name="SupportThinking" DataType="Boolean" Description="支持思考。是否支持思考模式" />
        <Column Name="SupportVision" DataType="Boolean" Description="支持视觉。是否支持图片输入" />
        <Column Name="SupportImageGeneration" DataType="Boolean" Description="支持图像生成。是否支持文生图" />
        <Column Name="SupportFunctionCalling" DataType="Boolean" Description="支持函数调用。是否支持Function Calling" />
        <Column Name="ApiProtocol" DataType="String" Description="API协议。ChatCompletions/ResponseApi/AnthropicMessages/Gemini" />
        <Column Name="Enable" DataType="Boolean" Description="启用" />
        <Column Name="Sort" DataType="Int32" Description="排序。越小越靠前" />
        <Column Name="CreateUserID" DataType="Int32" Description="创建用户" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="UpdateUserID" DataType="Int32" Description="更新用户" Category="扩展" />
        <Column Name="UpdateIP" DataType="String" Description="更新地址" Category="扩展" />
        <Column Name="UpdateTime" DataType="DateTime" Description="更新时间" Category="扩展" />
        <Column Name="Remark" DataType="String" Length="500" Description="备注" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="Code" Unique="True" />
        <Index Columns="Provider" />
      </Indexes>
    </Table>
    <Table Name="UserSetting" Description="用户设置。用户的个性化配置">
      <Columns>
        <Column Name="Id" DataType="Int32" Identity="True" PrimaryKey="True" Description="编号" />
        <Column Name="UserId" DataType="Int32" Description="用户。设置所属用户" />
        <Column Name="Language" DataType="String" Description="语言。zh-CN/zh-TW/en" />
        <Column Name="Theme" DataType="String" Description="主题。light/dark/system" />
        <Column Name="FontSize" DataType="Int32" Description="字体大小。14~20，默认16" />
        <Column Name="SendShortcut" DataType="String" Description="发送快捷键。Enter或Ctrl+Enter" />
        <Column Name="DefaultModel" DataType="String" Description="默认模型。新会话的默认模型编码" />
        <Column Name="DefaultThinkingMode" DataType="Int32" Description="默认思考模式。Auto=0, Think=1, Fast=2" />
        <Column Name="ContextRounds" DataType="Int32" Description="上下文轮数。每次请求携带的历史对话轮数，默认10" />
        <Column Name="SystemPrompt" DataType="String" ShowIn="Auto,-List,-Search" Length="2000" Description="系统提示词。全局System Prompt" />
        <Column Name="AllowTraining" DataType="Boolean" Description="允许训练。是否允许反馈数据用于模型改进" />
        <Column Name="McpEnabled" DataType="Boolean" Description="启用MCP。是否启用MCP工具调用" />
        <Column Name="DefaultSkill" DataType="String" Description="默认技能。新会话的默认技能编码" />
        <Column Name="StreamingSpeed" DataType="Int32" Description="流式速度。流式输出速度等级，1~5，默认3" />
        <Column Name="CreateUserID" DataType="Int32" Description="创建用户" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="UpdateUserID" DataType="Int32" Description="更新用户" Category="扩展" />
        <Column Name="UpdateIP" DataType="String" Description="更新地址" Category="扩展" />
        <Column Name="UpdateTime" DataType="DateTime" Description="更新时间" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="UserId" Unique="True" />
      </Indexes>
    </Table>
    <Table Name="AppKey" Description="应用密钥。API网关访问凭证，用于外部系统调用模型服务">
      <Columns>
        <Column Name="Id" DataType="Int32" Identity="True" PrimaryKey="True" Description="编号" />
        <Column Name="UserId" DataType="Int32" Description="用户。密钥所属用户" />
        <Column Name="Name" DataType="String" Master="True" Length="200" Description="名称。用户自定义标识，如业务系统A" />
        <Column Name="Secret" DataType="String" ShowIn="Auto,-List,-Search" Length="200" Description="密钥。sk-前缀的随机字符串，创建时仅展示一次" />
        <Column Name="Enable" DataType="Boolean" Description="启用" />
        <Column Name="ExpireTime" DataType="DateTime" Description="过期时间。null表示永不过期" />
        <Column Name="LastCallTime" DataType="DateTime" Description="最后调用时间" />
        <Column Name="Calls" DataType="Int64" Description="调用次数。累计API请求数" />
        <Column Name="TotalTokens" DataType="Int64" Description="总Token数。累计消耗Token" />
        <Column Name="CreateUserID" DataType="Int32" Description="创建用户" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="UpdateUserID" DataType="Int32" Description="更新用户" Category="扩展" />
        <Column Name="UpdateIP" DataType="String" Description="更新地址" Category="扩展" />
        <Column Name="UpdateTime" DataType="DateTime" Description="更新时间" Category="扩展" />
        <Column Name="Remark" DataType="String" Length="500" Description="备注" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="Secret" Unique="True" />
        <Index Columns="UserId" />
      </Indexes>
    </Table>
    <Table Name="UsageRecord" Description="用量记录。每次AI调用的Token消耗，支持按用户和AppKey双维度统计" InsertOnly="True">
      <Columns>
        <Column Name="Id" DataType="Int64" Identity="True" PrimaryKey="True" Description="编号" />
        <Column Name="UserId" DataType="Int32" Description="用户" />
        <Column Name="AppKeyId" DataType="Int32" Description="应用密钥。通过API网关调用时关联的AppKey" />
        <Column Name="ConversationId" DataType="Int64" Description="会话" />
        <Column Name="MessageId" DataType="Int64" Description="消息。对应的AI回复消息" />
        <Column Name="ModelCode" DataType="String" Description="模型编码" />
        <Column Name="PromptTokens" DataType="Int32" Description="提示Token数" />
        <Column Name="CompletionTokens" DataType="Int32" Description="回复Token数" />
        <Column Name="TotalTokens" DataType="Int32" Description="总Token数" />
        <Column Name="Source" DataType="String" Description="请求来源。Chat=对话/Gateway=网关" />
        <Column Name="TraceId" DataType="String" Description="链路追踪。方便问题排查" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="UserId,CreateTime" />
        <Index Columns="AppKeyId,CreateTime" />
        <Index Columns="ModelCode,CreateTime" />
        <Index Columns="ConversationId" />
      </Indexes>
    </Table>
    <Table Name="McpServerConfig" Description="MCP服务配置。MCP Server列表及工具发现信息">
      <Columns>
        <Column Name="Id" DataType="Int32" Identity="True" PrimaryKey="True" Description="编号" />
        <Column Name="Name" DataType="String" Master="True" Description="名称。服务名称" />
        <Column Name="Endpoint" DataType="String" Length="500" Description="接口地址。MCP Server地址" />
        <Column Name="TransportType" DataType="String" Description="传输类型。Http/Sse/Stdio" />
        <Column Name="AuthType" DataType="String" Description="认证类型。None/Bearer/ApiKey" />
        <Column Name="AuthToken" DataType="String" ShowIn="Auto,-List,-Search" Length="500" Description="认证令牌" />
        <Column Name="AvailableTools" DataType="String" ShowIn="Auto,-List,-Search" Length="-1" Description="可用工具。已发现的工具列表，JSON格式" />
        <Column Name="Enable" DataType="Boolean" Description="启用" />
        <Column Name="Sort" DataType="Int32" Description="排序。越小越靠前" />
        <Column Name="CreateUserID" DataType="Int32" Description="创建用户" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="UpdateUserID" DataType="Int32" Description="更新用户" Category="扩展" />
        <Column Name="UpdateIP" DataType="String" Description="更新地址" Category="扩展" />
        <Column Name="UpdateTime" DataType="DateTime" Description="更新时间" Category="扩展" />
        <Column Name="Remark" DataType="String" Length="500" Description="备注" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="Name" Unique="True" />
      </Indexes>
    </Table>
  </Tables>
</EntityModel>